rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: jobs
    // Document ID: jobId
    // Fields:
    //   - id: string (required)
    //   - niche: string (required)
    //   - city: string (optional)
    //   - ddd: string (optional)
    //   - sources: list (required)
    //   - max_pages_per_source: number (required)
    //   - status: string (required, enum: pending, running, completed, failed)
    //   - contacts_found: number (required)
    //   - created_at: timestamp (required)
    //   - uid: string (required)
    //
    // Collection: contacts
    // Document ID: contactId
    // Fields:
    //   - id: string (required)
    //   - name: string (optional)
    //   - category: string (optional)
    //   - e164_number: string (required)
    //   - raw_number: string (required)
    //   - source_url: string (required)
    //   - source_type: string (required)
    //   - niche: string (required)
    //   - address: string (optional)
    //   - city: string (optional)
    //   - job_id: string (required)
    //   - found_at: timestamp (required)
    //   - uid: string (required)
    //
    // Collection: error_logs
    // Document ID: logId
    // Fields:
    //   - id: string (required)
    //   - timestamp: timestamp (required)
    //   - source: string (required)
    //   - message: string (required)
    //   - stack: string (optional)
    //   - context: map (optional)
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "leodepaula83x@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidJob(data) {
      return hasRequiredFields(['id', 'niche', 'sources', 'status', 'created_at', 'uid']) &&
             data.id is string && data.id.size() > 0 &&
             data.niche is string && data.niche.size() > 0 && data.niche.size() < 100 &&
             data.sources is list && data.sources.size() > 0 && data.sources.size() <= 10 &&
             data.status in ['pending', 'running', 'completed', 'failed'] &&
             data.contacts_found is number &&
             data.created_at is timestamp &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidContact(data) {
      return hasRequiredFields(['id', 'e164_number', 'raw_number', 'job_id', 'found_at', 'uid']) &&
             data.id is string && data.id.size() > 0 &&
             data.e164_number is string && data.e164_number.size() > 0 && data.e164_number.size() < 20 &&
             data.raw_number is string && data.raw_number.size() > 0 && data.raw_number.size() < 30 &&
             data.job_id is string && data.job_id.size() > 0 &&
             data.found_at is timestamp &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidErrorLog(data) {
      return hasRequiredFields(['id', 'timestamp', 'source', 'message', 'uid']) &&
             data.id is string && data.id.size() > 0 &&
             data.timestamp is timestamp &&
             data.source is string && data.source.size() > 0 && data.source.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidBlacklistedContact(data) {
      return hasRequiredFields(['id', 'e164_number', 'created_at', 'uid']) &&
             data.id is string && data.id.size() > 0 &&
             data.e164_number is string && data.e164_number.size() > 0 && data.e164_number.size() < 20 &&
             data.created_at is timestamp &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /jobs/{jobId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isAuthenticated() && isValidJob(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if (isDocOwner() || isAdmin());
    }

    match /contacts/{contactId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidContact(request.resource.data);
      allow update: if isAuthenticated() && isValidContact(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if (isDocOwner() || isAdmin());
    }

    match /error_logs/{logId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidErrorLog(request.resource.data);
      allow update: if isAuthenticated() && isValidErrorLog(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /blacklist/{blacklistId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidBlacklistedContact(request.resource.data);
      allow update: if isAuthenticated() && isValidBlacklistedContact(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if (isDocOwner() || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }
  }
}
